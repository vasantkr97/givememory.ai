generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum Sender {
  user
  assistant
}

enum LlmProvider {
  openai
  openrouter
}

model User {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(100)
  email          String    @unique @db.VarChar(255)
  hashedPassword String    @map("hashed_password") @db.VarChar(255)
  isActive       Boolean   @default(true) @map("is_active")
  messageCount   Int       @default(0) @map("message_count")
  createdAt      DateTime  @default(now()) @map("created_at")

  apiKey       UserApiKey?
  refreshTokens RefreshToken[]
  chatMessages ChatMessage[]
  conversations Conversation[]

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tokenHash String   @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model UserApiKey {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique @map("user_id")
  encryptedApiKey String   @map("encrypted_api_key") @db.Text
  isValid         Boolean  @default(true) @map("is_valid")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_api_keys")
}

model ChatMessage {
  id                Int      @id @default(autoincrement())
  userId            Int      @map("user_id")
  role              Sender
  content           String   @db.Text
  extractedMemories Json?    @map("extracted_memories")
  createdAt         DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("chat_messages")
}

model Conversation {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  memories  Memory[]
  summary   ConversationSummary?

  @@index([userId])
  @@map("conversations")
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int          @map("conversation_id")
  sender         Sender
  messageText    String       @map("message_text") @db.Text
  timestamp      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, timestamp])
  @@map("messages")
}

model Memory {
  id             Int          @id @default(autoincrement())
  conversationId Int          @map("conversation_id")
  memoryText     String       @map("memory_text") @db.Text
  category       String?      @db.VarChar(64)
  embedding      Unsupported("vector(1536)")?
  metadata       Json?        @map("memory_metadata")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  isEpisodic     Boolean      @default(false) @map("is_episodic")
  occurredAt     DateTime?    @map("occurred_at")
  sessionId      Int?         @map("session_id")
  importance     Float        @default(0.5)
  isActive       Boolean      @default(true) @map("is_active")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, isActive])
  @@index([conversationId, isEpisodic])
  @@map("memories")
}

model ConversationSummary {
  id             Int          @id @default(autoincrement())
  conversationId Int          @unique @map("conversation_id")
  summaryText    String?      @map("summary_text") @db.Text
  updatedAt      DateTime     @updatedAt @map("updated_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("conversation_summary")
}

model ProviderSettings {
  id               Int         @id @default(1)
  llmProvider      LlmProvider @default(openai) @map("llm_provider")
  openaiApiKey     String?     @map("openai_api_key") @db.Text
  openrouterApiKey String?     @map("openrouter_api_key") @db.Text
  llmModel         String      @default("gpt-4o-mini") @map("llm_model")
  embeddingModel   String      @default("text-embedding-3-small") @map("embedding_model")
  debug            Boolean     @default(false)
  updatedAt        DateTime    @updatedAt @map("updated_at")

  @@map("provider_settings")
}
